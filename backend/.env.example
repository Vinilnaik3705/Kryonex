# Clerk Authentication
CLERK_PUBLISH_KEY=pk_live_YOUR_CLERK_PUBLISHABLE_KEY_HERE
CLERK_SECRET_KEY=sk_live_YOUR_CLERK_SECRET_KEY_HERE

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# OpenAI AI Configuration
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# Cache Configuration (in seconds)
CACHE_TTL_QUOTE=60
CACHE_TTL_HISTORY=300
CACHE_TTL_SEARCH=600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Binance API Configuration (optional - for authenticated endpoints)
# BINANCE_API_KEY=your_binance_api_key_here
# BINANCE_API_SECRET=your_binance_api_secret_here

# Razorpay keys (add your test/production keys here)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
